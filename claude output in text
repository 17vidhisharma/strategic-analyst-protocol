DIVIDE(
    [Total Sales],
    CALCULATE([Total Sales], ALL('Financials'[Segment])),
    0
)

-- Period-over-Period Profit Growth
Profit YoY % =
VAR CurrentYear = [Total Profit]
VAR PriorYear = CALCULATE([Total Profit], DATEADD('Financials'[Date], -1, YEAR))
RETURN DIVIDE(CurrentYear - PriorYear, ABS(PriorYear), 0)

-- Enterprise Loss Flag (for conditional formatting)
Is Enterprise Loss =
IF(
    SELECTEDVALUE('Financials'[Segment]) = "Enterprise"
        && [Gross Margin %] < 0,
    1, 0
)

