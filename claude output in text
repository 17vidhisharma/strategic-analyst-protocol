DIVIDE([Total Profit], SUM('Financials'[Units Sold]), 0)

-- Actual Discount Rate %
Discount Rate % =
DIVIDE(SUM('Financials'[Discounts]), SUM('Financials'[Gross Sales]), 0)

-- Revenue Share by Segment
